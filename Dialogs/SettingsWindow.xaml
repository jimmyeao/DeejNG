<Window
    x:Class="DeejNG.Dialogs.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="Settings"
    Width="900"
    Height="806"
    AllowsTransparency="True"
    Background="{DynamicResource BackgroundBrush}"
    FontFamily="Segoe UI"
    ResizeMode="NoResize"
    TextElement.FontSize="12"
    TextElement.FontWeight="Regular"
    TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
    TextOptions.TextFormattingMode="Ideal"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <shell:WindowChrome
                x:Key="Chrome"
                CaptionHeight="0"
                CornerRadius="8,8,8,8"
                GlassFrameThickness="0"
                ResizeBorderThickness="0"
                UseAeroCaptionButtons="False" />
        </ResourceDictionary>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <StaticResource ResourceKey="Chrome" />
    </shell:WindowChrome.WindowChrome>
    <DockPanel Margin="0,0,0,10">
        <Border Background="{DynamicResource SurfaceBrush}" DockPanel.Dock="Top">
            <Grid
                Height="48"
                Background="Transparent"
                MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Margin="20,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Text="⚙" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource TitleTextBlock}"
                        Text="Settings" />
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Margin="8,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="CloseButton_Click"
                    Content="✕"
                    Style="{StaticResource IconButton}"
                    ToolTip="Close" />
            </Grid>
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="18"
                        Style="{StaticResource TitleTextBlock}"
                        Text="General" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="20"
                        Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox
                                x:Name="SettingInvertSliders"
                                Margin="0,0,0,12"
                                Content="Invert Sliders"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                            <CheckBox
                                x:Name="SettingShowMeters"
                                Margin="0,0,0,12"
                                Content="Show Meters"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                            <CheckBox
                                x:Name="SettingStartOnBoot"
                                Margin="0,0,0,12"
                                Content="Start on boot"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                            <CheckBox
                                x:Name="SettingStartMinimized"
                                Margin="0,0,0,12"
                                Content="Start minimized"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                            <CheckBox
                                x:Name="SettingDisableSmoothing"
                                Margin="0,0,0,12"
                                Content="Disable Smoothing"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                            <CheckBox
                                x:Name="SettingUseExponentialVolume"
                                Margin="0,0,0,12"
                                Content="Use Exponential Volume"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Width="130"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource LabelTextBlock}"
                                    Text="Exp. Volume Factor" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Slider
                                        x:Name="ExponentialVolumeFactorSlider"
                                        Width="180"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True"
                                        Maximum="10.0"
                                        Minimum="1.5"
                                        TickFrequency="0.1" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource SubtitleTextBlock}"
                                        Text="{Binding ElementName=ExponentialVolumeFactorSlider, Path=Value, StringFormat={}{0:F1}}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="18"
                        Style="{StaticResource TitleTextBlock}"
                        Text="HID Device Information" />

                    <Border
                        Margin="0,0,0,20"
                        Padding="20"
                        Style="{StaticResource Card}">
                        <StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource LabelTextBlock}"
                                    Text="Vendor ID" />

                                <TextBox
                                    x:Name="HidVendorIdTextBox"
                                    Grid.Column="1"
                                    Width="160"
                                    HorizontalAlignment="Left"
                                    ToolTip="Example: 2341 or 0x2341" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource LabelTextBlock}"
                                    Text="Product ID" />

                                <TextBox
                                    x:Name="HidProductIdTextBox"
                                    Grid.Column="1"
                                    Width="160"
                                    HorizontalAlignment="Left"
                                    ToolTip="Example: 8036 or 0x8036" />
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Button
                                    Padding="16,8"
                                    HorizontalAlignment="Left"
                                    Click="OnSetNewHidID"
                                    Content="Set new HID ID's"
                                    Style="{StaticResource ModernButton}"
                                    ToolTip="Open button configuration dialog" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="18"
                        Style="{StaticResource TitleTextBlock}"
                        Text="Overlay" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="20"
                        Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox
                                x:Name="OverlayEnabledCheckBox"
                                Margin="0,0,0,16"
                                Content="Enable Overlay"
                                Foreground="{DynamicResource TextPrimaryBrush}" />

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Width="80"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource LabelTextBlock}"
                                    Text="Opacity" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Slider
                                        x:Name="OpacitySlider"
                                        Width="180"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True"
                                        Maximum="1.0"
                                        Minimum="0.0"
                                        TickFrequency="0.05" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource SubtitleTextBlock}"
                                        Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat={}{0:P0}}" />
                                </StackPanel>
                            </Grid>

                            <CheckBox
                                x:Name="AutoCloseCheckBox"
                                Margin="0,0,0,16"
                                Content="Auto-Close Overlay"
                                Foreground="{DynamicResource TextPrimaryBrush}" />

                            <Grid Margin="0,0,0,16" IsEnabled="{Binding IsChecked, ElementName=AutoCloseCheckBox}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Width="80"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource LabelTextBlock}"
                                    Text="Timeout (s)" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Slider
                                        x:Name="TimeoutSlider"
                                        Width="180"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True"
                                        Maximum="15"
                                        Minimum="1"
                                        TickFrequency="1" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource SubtitleTextBlock}"
                                        Text="{Binding ElementName=TimeoutSlider, Path=Value}" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Width="80"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource LabelTextBlock}"
                                    Text="Text Color" />
                                <ComboBox
                                    x:Name="TextColorComboBox"
                                    Grid.Column="1"
                                    Width="200"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource ModernComboBox}"
                                    ToolTip="Choose text color: Auto detects background, White/Black forces specific color">
                                    <ComboBoxItem Content="Auto (Smart Contrast)" />
                                    <ComboBoxItem Content="White Text" />
                                    <ComboBoxItem Content="Black Text" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock
                        FontSize="18"
                        Style="{StaticResource TitleTextBlock}"
                        Text="Unmapped Exclusions" />
                    <Border Padding="20" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource SubtitleTextBlock}"
                                Text="Apps excluded from 'Unmapped Applications' control:"
                                TextWrapping="Wrap" />
                            <ListBox
                                x:Name="ExcludedAppsListBox"
                                Height="100"
                                Margin="0,0,0,8"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                            <StackPanel Orientation="Horizontal">
                                <ComboBox
                                    x:Name="RunningAppsComboBox"
                                    Width="200"
                                    Margin="0,0,8,0"
                                    DropDownOpened="RunningAppsComboBox_DropDownOpened"
                                    Style="{StaticResource ModernComboBox}" />
                                <Button
                                    Padding="12,4"
                                    Click="AddExcludedApp_Click"
                                    Content="Add"
                                    Style="{StaticResource ModernButton}" />
                                <Button
                                    Margin="8,0,0,0"
                                    Padding="12,4"
                                    Click="RemoveExcludedApp_Click"
                                    Content="Remove"
                                    Style="{StaticResource ModernButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3">
                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="18"
                        Style="{StaticResource TitleTextBlock}"
                        Text="Physical Buttons (Experimental)" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="20"
                        Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,12"
                                Style="{StaticResource SubtitleTextBlock}"
                                Text="Configure physical buttons on your controller" />

                            <Button
                                Padding="16,8"
                                HorizontalAlignment="Left"
                                Click="ConfigureButtons_Click"
                                Content="Configure Buttons..."
                                Style="{StaticResource ModernButton}"
                                ToolTip="Open button configuration dialog" />
                        </StackPanel>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,16"
                        FontSize="18"
                        Style="{StaticResource TitleTextBlock}"
                        Text="Audio Device Presets" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="20"
                        Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,16"
                                Style="{StaticResource SubtitleTextBlock}"
                                Text="Store up to 3 audio output devices for button-based switching."
                                TextWrapping="Wrap" />

                            <!--  Preset 1  -->
                            <Border
                                Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="14"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Preset 1" />

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Audio Output" />

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Friendly Name" />

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="AudioDevice1FriendlyNameTextBox"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            ToolTip="Example: Speakers (Focusrite USB Audio)" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Device ID" />

                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="AudioDevice1IdTextBox"
                                            MinHeight="52"
                                            Padding="0"
                                            AcceptsReturn="True"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="Wrap"
                                            ToolTip="Paste the full Windows audio output device ID here" />
                                    </Border>

                                    <Separator Margin="0,0,0,12" />

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Microphone Input" />

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Friendly Name" />

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="MicrophoneDevice1FriendlyNameTextBox"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            ToolTip="Example: Microphone (Focusrite USB Audio)" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Device ID" />

                                    <Border
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="MicrophoneDevice1IdTextBox"
                                            MinHeight="52"
                                            Padding="0"
                                            AcceptsReturn="True"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="Wrap"
                                            ToolTip="Paste the full Windows microphone device ID here" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!--  Preset 2  -->
                            <Border
                                Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="14"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Preset 2" />

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Audio Output" />

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Friendly Name" />

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="AudioDevice2FriendlyNameTextBox"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            ToolTip="Example: Headphones (Sony WH-1000XM5)" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Device ID" />

                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="AudioDevice2IdTextBox"
                                            MinHeight="52"
                                            Padding="0"
                                            AcceptsReturn="True"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="Wrap"
                                            ToolTip="Paste the full Windows audio output device ID here" />
                                    </Border>

                                    <Separator Margin="0,0,0,12" />

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Microphone Input" />

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Friendly Name" />

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="MicrophoneDevice2FriendlyNameTextBox"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            ToolTip="Example: Microphone (Sony WH-1000XM5)" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Device ID" />

                                    <Border
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="MicrophoneDevice2IdTextBox"
                                            MinHeight="52"
                                            Padding="0"
                                            AcceptsReturn="True"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="Wrap"
                                            ToolTip="Paste the full Windows microphone device ID here" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!--  Preset 3  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="12"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="14"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Preset 3" />

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Audio Output" />

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Friendly Name" />

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="AudioDevice3FriendlyNameTextBox"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            ToolTip="Example: LG HDR 4K" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Device ID" />

                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="AudioDevice3IdTextBox"
                                            MinHeight="52"
                                            Padding="0"
                                            AcceptsReturn="True"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="Wrap"
                                            ToolTip="Paste the full Windows audio output device ID here" />
                                    </Border>

                                    <Separator Margin="0,0,0,12" />

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Microphone Input" />

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Friendly Name" />

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="MicrophoneDevice3FriendlyNameTextBox"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            ToolTip="Example: Microphone (LG HDR 4K)" />
                                    </Border>

                                    <TextBlock
                                        Margin="0,0,0,4"
                                        Style="{StaticResource LabelTextBlock}"
                                        Text="Device ID" />

                                    <Border
                                        Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <TextBox
                                            x:Name="MicrophoneDevice3IdTextBox"
                                            MinHeight="52"
                                            Padding="0"
                                            AcceptsReturn="True"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="Wrap"
                                            ToolTip="Paste the full Windows microphone device ID here" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,0,0,16" />

                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="14"
                                Style="{StaticResource LabelTextBlock}"
                                Text="Available Audio Devices" />

                            <TextBlock
                                Margin="0,0,0,12"
                                Style="{StaticResource SubtitleTextBlock}"
                                Text="Use this list to copy the Friendly Name and Device ID of currently available output devices."
                                TextWrapping="Wrap" />

                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                <Button
                                    x:Name="LogAudioDevicesButton"
                                    Padding="14,6"
                                    Click="LogAudioDevicesButton_Click"
                                    Content="Log Devices"
                                    Style="{StaticResource ModernButton}" />
                            </StackPanel>

                            <ListBox
                                x:Name="AvailableAudioDevicesListBox"
                                Height="540"
                                Padding="4"
                                HorizontalContentAlignment="Stretch"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="12"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel>

                                                <TextBlock
                                                    Margin="0,0,0,4"
                                                    Style="{StaticResource LabelTextBlock}"
                                                    Text="Friendly Name" />

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border
                                                        Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        Padding="8,6"
                                                        Background="{DynamicResource BackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                        <TextBox
                                                            Padding="0"
                                                            VerticalContentAlignment="Center"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                                            IsReadOnly="True"
                                                            Text="{Binding FriendlyName}" />
                                                    </Border>

                                                    <Button
                                                        Grid.Column="1"
                                                        Width="32"
                                                        Height="32"
                                                        Click="CopyAudioDeviceField_Click"
                                                        Content="⧉"
                                                        Style="{StaticResource IconButton}"
                                                        Tag="{Binding FriendlyName}"
                                                        ToolTip="Copy Friendly Name" />
                                                </Grid>

                                                <TextBlock
                                                    Margin="0,0,0,4"
                                                    Style="{StaticResource LabelTextBlock}"
                                                    Text="Device ID" />

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border
                                                        Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        Padding="8,6"
                                                        Background="{DynamicResource BackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                        <TextBox
                                                            MinHeight="44"
                                                            Padding="0"
                                                            AcceptsReturn="True"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            FontFamily="Consolas"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                                            IsReadOnly="True"
                                                            Text="{Binding Id}"
                                                            TextWrapping="Wrap" />
                                                    </Border>

                                                    <Button
                                                        Grid.Column="1"
                                                        Width="32"
                                                        Height="32"
                                                        VerticalAlignment="Top"
                                                        Click="CopyAudioDeviceField_Click"
                                                        Content="⧉"
                                                        Style="{StaticResource IconButton}"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Copy Device ID" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock
                                Margin="0,16,0,8"
                                FontSize="14"
                                Style="{StaticResource LabelTextBlock}"
                                Text="Available Microphone Devices" />

                            <TextBlock
                                Margin="0,0,0,12"
                                Style="{StaticResource SubtitleTextBlock}"
                                Text="Use this list to copy the Friendly Name and Device ID of currently available microphone devices."
                                TextWrapping="Wrap" />

                            <ListBox
                                x:Name="AvailableMicrophoneDevicesListBox"
                                Height="540"
                                Padding="4"
                                HorizontalContentAlignment="Stretch"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="12"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel>

                                                <TextBlock
                                                    Margin="0,0,0,4"
                                                    Style="{StaticResource LabelTextBlock}"
                                                    Text="Friendly Name" />

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border
                                                        Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        Padding="8,6"
                                                        Background="{DynamicResource BackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                        <TextBox
                                                            Padding="0"
                                                            VerticalContentAlignment="Center"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                                            IsReadOnly="True"
                                                            Text="{Binding FriendlyName}" />
                                                    </Border>

                                                    <Button
                                                        Grid.Column="1"
                                                        Width="32"
                                                        Height="32"
                                                        Click="CopyAudioDeviceField_Click"
                                                        Content="⧉"
                                                        Style="{StaticResource IconButton}"
                                                        Tag="{Binding FriendlyName}"
                                                        ToolTip="Copy Friendly Name" />
                                                </Grid>

                                                <TextBlock
                                                    Margin="0,0,0,4"
                                                    Style="{StaticResource LabelTextBlock}"
                                                    Text="Device ID" />

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border
                                                        Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        Padding="8,6"
                                                        Background="{DynamicResource BackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                        <TextBox
                                                            MinHeight="44"
                                                            Padding="0"
                                                            AcceptsReturn="True"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            FontFamily="Consolas"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                                            IsReadOnly="True"
                                                            Text="{Binding Id}"
                                                            TextWrapping="Wrap" />
                                                    </Border>

                                                    <Button
                                                        Grid.Column="1"
                                                        Width="32"
                                                        Height="32"
                                                        VerticalAlignment="Top"
                                                        Click="CopyAudioDeviceField_Click"
                                                        Content="⧉"
                                                        Style="{StaticResource IconButton}"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Copy Device ID" />
                                                </Grid>

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,10,0"
                        Click="Save_Click"
                        Content="Save"
                        Style="{StaticResource ModernButton}" />
                    <Button
                        Click="Cancel_Click"
                        Content="Cancel"
                        Style="{StaticResource ModernButton}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>